# MusicGrowth.ai environment template
# Copy to .env at project root and fill required values.

# Required security setting
# Use a random secret with at least 32 characters.
JWT_SECRET_KEY=replace-with-a-random-32-plus-character-secret

# Database
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=musicgrowth

# Auth token expiration (minutes)
JWT_EXPIRE_MINUTES=43200

# Optional external model config
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional dataset overrides
SPOTIFY_DATASET_APRIL=
SPOTIFY_DATASET_NOV=
SPOTIFY_MIN_POPULARITY=35
